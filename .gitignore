# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# OS Files
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Editor Directories
.idea/
.vscode/
*.swp
*.swo

# Project Data & Large Files (Prevent accidental pushes of datasets)
*.csv
*.xlsx
*.xls
*.parquet
*.db
*.sqlite
*.sql

# Large Media
*.mp4
*.mov
*.avi
*.wmv

# Local Fonts (Optional: comment out if you want to push fonts)
# src/fonts/*.ttf
# src/fonts/*.otf
# src/fonts/*.woff2
